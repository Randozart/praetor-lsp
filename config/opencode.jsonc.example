{
  "$schema": "https://opencode.ai/config.json",
  /* Object form keeps built-in LSPs active while adding custom servers */
  "lsp": {
    "sonar": {
      "command": ["java", "-jar", "/home/randozart/praetor-lsp/lib/sonarlint-language-server.jar", "-stdio"],
      "extensions": [".py", ".js", ".ts", ".go", ".java", ".cpp", ".c", ".cs", ".rb", ".rs"]
    },
    "infer": {
      "command": ["python3", "/home/randozart/praetor-lsp/scripts/infer_lsp.py"],
      "extensions": [".c", ".cpp", ".cc", ".h", ".hpp", ".java", ".cs", ".m", ".mm"]
    },
    "complexity": {
      "command": ["python3", "/home/randozart/praetor-lsp/scripts/complexity_lsp.py"],
      "extensions": ["*"]
    },
    "haskell": {
      "command": ["haskell-language-server-wrapper", "--lsp"],
      "extensions": [".hs", ".lhs"]
    },
    "ada": {
      "command": ["ada_language_server", "--stdio"],
      "extensions": [".adb", ".ads"]
    }
  }
}
